<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender with color support -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%-30.30logger{30})] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender for full debug log -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>target/functional-test-logs/framework.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>target/functional-test-logs/framework.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%logger{40}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Framework core: INFO on console, DEBUG to file -->
    <logger name="com.banking.testframework" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Container-level logs: shows stdout/stderr from each container -->
    <logger name="container" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Testcontainers internal: warn only to reduce noise -->
    <logger name="org.testcontainers" level="WARN"/>
    <logger name="com.github.dockerjava" level="WARN"/>
    <logger name="tc" level="WARN"/>

    <!-- WireMock: warn only -->
    <logger name="com.github.tomakehurst.wiremock" level="WARN"/>

    <!-- OkHttp: warn only -->
    <logger name="okhttp3" level="WARN"/>

    <!-- AWS SDK: warn only -->
    <logger name="software.amazon.awssdk" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
